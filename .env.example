# ---------------------------------------------------------------------------
# Environment variables. Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit real endpoints/secrets.
# ---------------------------------------------------------------------------

# Base URL of the Laravel API. Leave blank during the mock-data phase.
# When set, the app stops using mock data and calls this API (see src/lib/config.js).
# Example: https://api.scriptguru.example
NEXT_PUBLIC_API_BASE_URL=

# Force mock data on/off explicitly (optional).
#   - unset / "true"  → use mock data (default while API_BASE_URL is empty)
#   - "false"         → use the real API (also implied once API_BASE_URL is set)
NEXT_PUBLIC_USE_MOCK_DATA=true
